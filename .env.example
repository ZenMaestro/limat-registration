# Environment Variables Template
# Copy this to .env and fill in actual values
# NEVER commit .env file with real secrets!

# Server
PORT=5000
NODE_ENV=development

# Database (Local Development)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=limat_registration
DB_USER=root
DB_PASSWORD=Likhith@1981

# Database (Production - Use Azure MySQL or PlanetScale)
# DB_HOST=limat-mysql.mysql.database.azure.com
# DB_USER=dbadmin@limat-mysql
# DB_PASSWORD=YourSecurePassword123!
# DB_NAME=limat_prod

# JWT
JWT_SECRET=your_secret_key_here_change_in_production

# Email (Optional - for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@limat.edu

# Frontend
FRONTEND_URL=http://localhost:8000
FRONTEND_PROD_URL=https://your-domain.com

# Admin Panel
ADMIN_PANEL_URL=http://localhost:8000/admin
ADMIN_PROD_URL=https://your-domain.com/admin

# Session
SESSION_SECRET=session_secret_change_in_production
SESSION_TIMEOUT=86400000

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Features (Toggle)
ENABLE_NOTIFICATIONS=true
ENABLE_EMAIL=false
ENABLE_ANALYTICS=true
